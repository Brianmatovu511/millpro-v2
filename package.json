{
  "name": "millpro-enterprise",
  "version": "2.2.0",
  "description": "MillPro Enterprise — Milling Management System",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "nodemon server/index.js",
    "dev:client": "cd client && npm run dev",
    "build": "cd client && npm run build",
    "start": "NODE_ENV=production node server/index.js",
    "db:push": "npx prisma db push",
    "db:seed": "node prisma/seed.js",
    "db:studio": "npx prisma studio",
    "setup": "npm install && cd client && npm install && cd .. && npx prisma generate && npm run prepare",
    "test": "jest --testPathPattern=tests/",
    "lint": "eslint server/ tests/ --ext .js",
    "lint:fix": "eslint server/ tests/ --ext .js --fix",
    "prepare": "husky install || true"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "express-rate-limit": "^7.4.1",
    "express-validator": "^7.3.2",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "uuid": "^11.0.3",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "eslint": "^9.39.4",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "nodemon": "^3.1.7",
    "prisma": "^5.22.0",
    "supertest": "^7.2.2"
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "server/fhir/**/*.js",
      "server/utils/logger.js",
      "server/middleware/errorHandler.js",
      "server/middleware/correlationId.js",
      "server/middleware/validate.js"
    ],
    "coverageReporters": [
      "text",
      "lcov",
      "html"
    ],
    "coverageThreshold": {
      "global": {
        "lines": 80
      }
    }
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
